---
interface Props {
  href: string;
  label?: string;
}

const { href, label } = Astro.props;
---

<div
  class="mr-3 h-10 w-full rounded-xl p-[2px] shadow-[inset_0_0_0_1px_rgba(0,0,0,0.1)] transition-all duration-300 hover:bg-accent/20 sm:w-24"
>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={label ? label : undefined}
    class="flex h-full w-full items-center justify-center rounded-lg bg-secondary px-4 py-2 text-sm font-medium text-gray-900 shadow-sm transition-all duration-200 ease-in-out hover:bg-white active:scale-95"
  >
    <slot />
  </a>
</div>
