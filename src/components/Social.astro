---
interface Props {
  href: string;
  label?: string;
}

const { href, label } = Astro.props;
---

<div
  class="hover:bg-accent/20 mr-3 h-10 w-full rounded-full p-[2px] transition-all duration-300 sm:w-24"
>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={label ? label : undefined}
    class="flex h-full w-full items-center justify-center rounded-lg bg-black/5 p-1 px-4 py-2 text-sm font-medium text-gray-900 shadow-sm backdrop-blur-md transition-all duration-200 ease-in-out active:scale-95"
  >
    <slot />
  </a>
</div>
